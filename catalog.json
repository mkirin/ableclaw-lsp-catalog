        "Spring Boot",
        "Maven",
        "Gradle",
        ".properties · .yml"
      ],
      "fileTypes": [
        ".java",
        "application.properties",
        "application.yml",
        "pom.xml",
        "build.gradle"
      ],
      "languages": [
        "java",
        "spring-boot-properties",
        "spring-boot-properties-yaml"
      ],
      "sizeBytes": 133711392,
