      "requirements": {
        "java": {
          "min": "17"
        }
      },
      "components": [
        {
          "id": "jdt.ls",
          "name": "eclipse.jdt.ls",
          "version": "1.61.0-202607102111",
          "sizeBytes": 50952249,
          "downloadUrl": "https://download.eclipse.org/jdtls/snapshots/jdt-language-server-1.61.0-202607102111.tar.gz",
          "sha256": "319b60ef9566a0f33204331b3ad8265551e19684297bb018dc701c5a8c5d398a",
          "unpack": "tar.gz",
          "launcher": {
            "command": "${java}",
            "args": [
              "-Declipse.application=org.eclipse.jdt.ls.core.id1",
              "-Dosgi.bundles.defaultStartLevel=4",
              "-Declipse.product=org.eclipse.jdt.ls.core.product",
              "-Dlog.level=ALL",
              "-Xmx1G",
              "--add-modules=ALL-SYSTEM",
              "--add-opens",
              "java.base/java.util=ALL-UNNAMED",
              "--add-opens",
              "java.base/java.lang=ALL-UNNAMED",
              "-jar",
              "${componentDir}/plugins/org.eclipse.equinox.launcher_*.jar",
              "-configuration",
              "${componentDir}/config_${platform}",
              "-data",
              "${dataDir}/jdt.ls"
            ]
          }
        },
